# --- Required ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Long random string used to sign JWTs.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# --- Server ---
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# --- Production CORS ---
# Comma-separated frontend origins. Required when NODE_ENV=production.
CORS_ORIGIN=https://your-frontend.example.com

# --- Optional ---
DB_POOL_MAX=5

# --- Optional: override seed admin (used by `node migrations/seed-admin.js`) ---
# SEED_ADMIN_USERNAME=superadmin
# SEED_ADMIN_PASSWORD=change-me-on-first-deploy
# SEED_ADMIN_FULL_NAME=Super Admin
