# --- Required ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# --- Server ---
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# --- Production CORS ---
# Comma-separated frontend origins. Required when NODE_ENV=production.
CORS_ORIGIN=https://your-frontend.example.com

# --- Optional ---
DB_POOL_MAX=5
