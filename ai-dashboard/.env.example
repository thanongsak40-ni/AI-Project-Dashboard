# --- Required ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# --- Server ---
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# --- Production CORS (comma-separated origins) ---
# Required when NODE_ENV=production AND frontend served from a different origin.
# Leave empty for single-origin deploy (server serves /dist).
CORS_ORIGIN=

# --- Optional ---
DB_POOL_MAX=5

# --- Frontend (build-time) ---
# Leave empty to use same-origin (recommended). Set to backend URL only when
# frontend is hosted separately, e.g. https://api.example.com
VITE_API_BASE=
